{
  "name": "dosho",
  "version": "1.0.0",
  "description": "Dosho Trading Journal",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "create-icons": "node scripts/create-icons.js"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "com.dosho.app",
    "productName": "Dosho",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "index.html",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "mt5_bridge/dist/mt5_bridge.exe",
        "to": "mt5_bridge.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Dosho"
    },
    "publish": {
      "provider": "github",
      "owner": "MisterZerograde",
      "repo": "Dosho-app"
    }
  }
}
